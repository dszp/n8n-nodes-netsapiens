{
    "name": "n8n-nodes-netsapiens",
    "version": "0.1.2",
    "description": "n8n Community Node for connecting to and querying NetSapiens-based VoIP phone switch/PBX. ",
    "license": "MIT",
    "homepage": "",
    "keywords": [
        "n8n-community-node-package",
        "n8n",
        "netsapiens",
        "voip",
        "pbx"
    ],
    "author": {
        "name": "David Szpunar",
        "url": "https://david.szpunar.com"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/dszp/n8n-nodes-netsapiens.git"
    },
    "scripts": {
        "generate": "node tools/generate-openapi.js",
        "build": "npm run generate && n8n-node build",
        "build:watch": "tsc --watch",
        "dev": "n8n-node dev",
        "lint": "n8n-node lint",
        "lint:fix": "n8n-node lint --fix",
        "release": "n8n-node release"
    },
    "files": [
        "dist"
    ],
    "n8n": {
        "n8nNodesApiVersion": 1,
        "strict": true,
        "credentials": [
            "dist/credentials/NetSapiensApi.credentials.js"
        ],
        "nodes": [
            "dist/nodes/NetSapiens/NetSapiens.node.js"
        ]
    },
    "devDependencies": {
        "@n8n/node-cli": "*",
        "@types/node": "^22.10.2",
        "eslint": "9.32.0",
        "openapi-types": "^12.1.3",
        "prettier": "3.6.2",
        "release-it": "^19.0.4",
        "tsx": "^4.19.2",
        "typescript": "5.9.2"
    },
    "peerDependencies": {
        "n8n-workflow": "*"
    }
}
